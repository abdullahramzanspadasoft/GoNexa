# Copy this file to `.env.local` (do NOT commit real secrets)
#
# MongoDB
MONGO_URI=mongodb://localhost:27017/nexaAi
JWT_SECRET=your_jwt_secret_here
#
# NextAuth (Google OAuth)
# Google Cloud Console -> Authorized redirect URI must be:
#   http://localhost:3000/api/auth/callback/google
# (NOT https://localhost... unless you are running local HTTPS)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_long_random_string
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here
